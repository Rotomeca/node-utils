{
  "name": "@rotomeca/utils",
  "version": "6.1.0",
  "description": "Various helpers",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json && node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'}, null, 2))\"",
    "build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}, null, 2))\"",
    "bundle": "node build-bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rotomeca/node-utils.git"
  },
  "keywords": [
    "utils"
  ],
  "author": "Rotomeca",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Rotomeca/node-utils/issues"
  },
  "homepage": "https://github.com/Rotomeca/node-utils#readme",
  "devDependencies": {
    "@typescript-eslint/parser": "^5.62.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "sideEffects": false
}
